CYAN='\033[1;36m'
GREEN='\033[1;32m'
RED='\033[1;31m'
YELLOW='\033[1;33m'
PURPLE='\033[1;35m'
BLUE='\033[1;34m'
WHITE='\033[1;37m'
NC='\033[0m'

step() {
    # We use echo -e to make the boxes look sharp
    echo -e "\n${BLUE}┌──[ ARCHITECT LOGIC ]─────────────────────────────────────┐${NC}"
    echo -e "${BLUE}│${NC} ${WHITE}$2${NC}"
    echo -e "${BLUE}├──────────────────────────────────────────────────────────┤${NC}"
    echo -e "${BLUE}│${NC} ${CYAN}ACTION: $1${NC}"
    echo -e "${BLUE}└──────────────────────────────────────────────────────────┘${NC}"
    echo -ne "${PURPLE}>> PRESS [ANY KEY] TO EXECUTE STRIKE...${NC}"
    
    # Pause logic - only works in Zsh
    read -k 1 -s
    
    echo -e "\n${YELLOW}[EXECUTING...]${NC}"
    eval $1
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}[✔] SUCCESS.${NC}"
    else
        echo -e "${RED}[✘] FLINCHED.${NC}"
    fi
}

